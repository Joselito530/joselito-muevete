<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Joselito, muevete o muere!" android:textColor="@color/accent"
            android:textSize="18sp" android:textStyle="bold" android:gravity="center"
            android:paddingBottom="8dp" />
        <TextView android:id="@+id/tvNextAlarm" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Desactivado"
            android:textColor="@color/text_secondary" android:textSize="14sp"
            android:gravity="center" android:paddingBottom="12dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@color/bg_card"
            android:padding="12dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Ejercicio actual" android:textColor="@color/text_secondary"
                android:textSize="12sp" android:paddingBottom="4dp" />
            <TextView android:id="@+id/tvCurrentExercise" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="10 sentadillas"
                android:textColor="@color/text_primary" android:textSize="18sp"
                android:textStyle="bold" android:paddingBottom="8dp" />
            <Button android:id="@+id/btnEditExercises" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="Editar lista de ejercicios"
                android:textColor="@color/white" android:textSize="13sp"
                android:background="@color/bg_dark" />
        </LinearLayout>
        <TextView android:id="@+id/tvIntervalLabel" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Cada hora"
            android:textColor="@color/accent" android:textSize="15sp" android:textStyle="bold"
            android:gravity="center" android:paddingBottom="6dp" />
        <SeekBar android:id="@+id/seekInterval" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:max="21" android:progress="9"
            android:thumbTint="@color/accent" android:progressTint="@color/accent"
            android:layout_marginBottom="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="15 min"
                android:textColor="@color/text_secondary" android:textSize="11sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="2 h"
                android:textColor="@color/text_secondary" android:textSize="11sp" android:gravity="end" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Periodo manana" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:paddingBottom="6dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:id="@+id/tvStartTime1" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="Inicio: 08:00"
                android:textColor="@color/text_primary" android:textSize="14sp"
                android:gravity="center" android:background="@color/bg_card" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/tvEndTime1" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="Fin: 14:00"
                android:textColor="@color/text_primary" android:textSize="14sp"
                android:gravity="center" android:background="@color/bg_card" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Pausa (comida/descanso)" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:paddingBottom="6dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:id="@+id/tvPauseStart" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="Pausa desde: 14:00"
                android:textColor="@color/text_primary" android:textSize="13sp"
                android:gravity="center" android:background="@color/bg_card" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/tvPauseEnd" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="hasta: 17:00"
                android:textColor="@color/text_primary" android:textSize="13sp"
                android:gravity="center" android:background="@color/bg_card" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Periodo tarde" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:paddingBottom="6dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:id="@+id/tvStartTime2" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="Inicio: 17:00"
                android:textColor="@color/text_primary" android:textSize="14sp"
                android:gravity="center" android:background="@color/bg_card" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/tvEndTime2" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="Fin: 22:00"
                android:textColor="@color/text_primary" android:textSize="14sp"
                android:gravity="center" android:background="@color/bg_card" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Tipo de aviso" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:paddingBottom="6dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@color/bg_card"
            android:padding="12dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Sonido"
                    android:textColor="@color/text_primary" android:textSize="15sp" />
                <Switch android:id="@+id/switchSound" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:checked="true"
                    android:thumbTint="@color/accent" android:trackTint="@color/bg_dark" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_dark" android:layout_marginVertical="6dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Vibracion"
                    android:textColor="@color/text_primary" android:textSize="15sp" />
                <Switch android:id="@+id/switchVibration" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:checked="true"
                    android:thumbTint="@color/accent" android:trackTint="@color/bg_dark" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_dark" android:layout_marginVertical="6dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Pantalla emergente"
                    android:textColor="@color/text_primary" android:textSize="15sp" />
                <Switch android:id="@+id/switchOverlay" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:checked="true"
                    android:thumbTint="@color/accent" android:trackTint="@color/bg_dark" />
            </LinearLayout>
        </LinearLayout>
        <Button android:id="@+id/btnToggle" android:layout_width="match_parent"
            android:layout_height="56dp" android:text="ACTIVAR"
            android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"
            android:background="@color/color_start" />
    </LinearLayout>
</ScrollView>
